# Section 11: Income Distribution by Default Status

```{r income-default, fig.cap="Figure 9: Monthly Income Distribution by Default Status", fig.width=7, fig.height=4}
ggplot(df, aes(x = monthly_income, fill = default_flag)) +
  geom_density(alpha = 0.5) +
  scale_fill_manual(values = c("No Default" = "#2196F3", "Default" = "#F44336"),
                    name = "Default Status") +
  scale_x_continuous(labels = dollar) +
  labs(title = "Monthly Income Distribution by Default Status",
       x = "Monthly Income (USD)", y = "Density") +
  theme_minimal(base_size = 12) +
  theme(plot.title = element_text(face = "bold"),
