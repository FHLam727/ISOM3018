library(tidyverse)
library(scales)
library(knitr)
library(kableExtra)
library(lubridate)
library(corrplot)
library(gridExtra)
df <- read_csv("Buy_Now_Pay_Later_BNPL_CreditRisk_Dataset.csv")
df <- df %>%
mutate(
default_flag     = factor(default_flag, levels = c(0,1),
labels = c("No Default","Default")),
employment_type  = factor(employment_type),
product_category = factor(product_category),
location         = factor(location),
customer_segment = factor(customer_segment),
bnpl_installments = factor(bnpl_installments),
transaction_date = mdy(transaction_date)
)
View(df)
install.packages("tinytex")
tinytex::is_tinytex()
readLines("EDA.log")
tinytex::reinstall_tinytex()
options(tinytex.installer = "TinyTeX")
tinytex::install_tinytex(force = TRUE)
